# ─── Load keys ───
_load_keys() {
  if [ -f "$HERMES_KEYS" ]; then
    source "$HERMES_KEYS" 2>/dev/null
  fi
  # Fallback to env
  TOKEN="${TOKEN:-${HERMES_TOKEN:-}}"
  GROQ_KEY="${GROQ_KEY:-${GROQ_API_KEY:-}}"
  OR_KEY="${OR_KEY:-${OPENROUTER_API_KEY:-}}"
  GEMINI_KEY="${GEMINI_KEY:-${GOOGLE_API_KEY:-${GEMINI_API_KEY:-}}}"
  GITHUB_PAT="${GITHUB_PAT:-${GH_TOKEN:-}}"
  DEFAULT_MODEL="${DEFAULT_MODEL:-llama-3.3-70b-versatile}"
  DEFAULT_PROVIDER="${DEFAULT_PROVIDER:-groq}"
  DEFAULT_GATEWAY="${DEFAULT_GATEWAY:-$GATEWAY_CF}"
}

# ─── Colors ───
