# ─── Status ───
cmd_status() {
  _load_keys
  _header "📊 STATUS — All Connections"
  echo ""

  # Gateway
  printf '  %sCloudflare Workers:%s\n' "$W" "$N"
  for ep in "dashboard/status:Dashboard" "health:Health" "v1/models:Models" "solace/status:Solace"; do
    path="${ep%%:*}"
    name="${ep##*:}"
    code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 8 "$GATEWAY_CF/$path" 2>/dev/null || echo "000")
    if [ "$code" = "200" ]; then
      printf '  %s✅ %-20s %s%s\n' "$G" "$name" "$code" "$N"
    else
      printf '  %s❌ %-20s %s%s\n' "$R" "$name" "$code" "$N"
    fi
  done

  # Cloud Run
  echo ""
  printf '  %sCloud Run App:%s\n' "$W" "$N"
  for ep in "health:Health" "dashboard/status:Dashboard" "v1/models:Models"; do
    path="${ep%%:*}"
    name="${ep##*:}"
    code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 8 "$GATEWAY_RUN/$path" 2>/dev/null || echo "000")
    if [ "$code" = "200" ]; then
      printf '  %s✅ %-20s %s%s\n' "$G" "$name" "$code" "$N"
    else
      printf '  %s❌ %-20s %s%s\n' "$R" "$name" "$code" "$N"
    fi
  done

  # AI Providers
  echo ""
  printf '  %sAI Providers:%s\n' "$W" "$N"
  _test_provider groq "Groq"
  _test_provider openrouter "OpenRouter"
  _test_provider gemini "Gemini"

  # GitHub
  echo ""
  printf '  %sGitHub:%s\n' "$W" "$N"
  if [ -n "$GITHUB_PAT" ]; then
    local user
    user=$(curl -s --max-time 8 -H "Authorization: token $GITHUB_PAT" "https://api.github.com/user" 2>/dev/null | python3 -c "import json,sys; print(json.load(sys.stdin).get('login','?'))" 2>/dev/null)
    if [ "$user" != "?" ] && [ -n "$user" ]; then
      printf '  %s✅ %-20s %s%s\n' "$G" "User" "$user" "$N"
    else
      printf '  %s❌ %-20s %s%s\n' "$R" "PAT" "expired" "$N"
    fi
  else
    printf '  %s⏭  %-20s %s%s\n' "$D" "GitHub PAT" "not set" "$N"
  fi

  echo ""
}

# ─── Scan Models ───
cmd_scan() {
  _load_keys
  _header "🔍 SCANNING MODELS"

  local models=(
    "groq|llama-3.3-70b-versatile|Llama 3.3 70B"
    "groq|qwen/qwen3-32b|Qwen3 32B"
    "groq|qwen/qwen3.6-27b|Qwen3.6 27B"
    "groq|meta-llama/llama-4-scout-17b-16e-instruct|Llama 4 Scout"
    "groq|openai/gpt-oss-120b|GPT-OSS 120B"
    "groq|groq/compound|Compound"
    "groq|llama-3.1-8b-instant|Llama 3.1 8B"
    "openrouter|google/gemini-2.5-flash|Gemini 2.5 Flash"
    "openrouter|google/gemini-2.5-pro-preview|Gemini 2.5 Pro"
    "openrouter|deepseek/deepseek-r1|DeepSeek R1"
    "gemini|gemini-2.5-flash|Gemini Flash (direct)"
    "gemini|gemini-2.5-pro|Gemini Pro (direct)"
  )

  for entry in "${models[@]}"; do
    local prov="${entry%%|*}"
    local rest="${entry#*|}"
    local mid="${rest%%|*}"
    local name="${rest##*|}"

    local t0 code ms
    t0=$(date +%s%3N 2>/dev/null || date +%s)

    case "$prov" in
      groq)
        code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 10 \
          -H "Authorization: Bearer $GROQ_KEY" -H "Content-Type: application/json" \
          -d "{\"model\":\"$mid\",\"messages\":[{\"role\":\"user\",\"content\":\"hi\"}],\"max_tokens\":1}" \
          "https://api.groq.com/openai/v1/chat/completions" 2>/dev/null || echo "000")
        ;;
      openrouter)
        code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 15 \
          -H "Authorization: Bearer $OR_KEY" -H "Content-Type: application/json" \
          -d "{\"model\":\"$mid\",\"messages\":[{\"role\":\"user\",\"content\":\"hi\"}],\"max_tokens\":1}" \
          "https://openrouter.ai/api/v1/chat/completions" 2>/dev/null || echo "000")
        ;;
      gemini)
        code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 10 \
          "https://generativelanguage.googleapis.com/v1beta/models?key=$GEMINI_KEY" 2>/dev/null || echo "000")
        ;;
    esac

    ms=$(( $(date +%s%3N 2>/dev/null || date +%s) - t0 ))

    if [ "$code" = "200" ]; then
      printf '  %s✅ %-22s %-40s %4sms%s\n' "$G" "$name" "$mid" "$ms" "$N"
    else
      printf '  %s❌ %-22s %-40s HTTP %s%s\n' "$R" "$name" "$mid" "$code" "$N"
    fi
  done
  echo ""
}

# ─── Deploy ───
cmd_deploy() {
  _load_keys
  local target="${1:-}"

  _header "🚀 DEPLOY"

  case "$target" in
    cf|cloudflare)
      _info "Deploying to hermes-cloudflare..."
      if command -v npx &>/dev/null; then
        cd "${HERMES_DIR}/repo/cloudflare-gateway" 2>/dev/null && npx wrangler deploy && _ok "Deployed!" || _err "cd to repo first: hermes clone"
      else
        _err "Install wrangler: npm install -g wrangler"
      fi
      ;;
    firebase)
      _info "Deploying to Firebase Hosting ($FIREBASE_PROJECT)..."
      if command -v firebase &>/dev/null; then
        cd "${HERMES_DIR}/repo/firebase-hosting" 2>/dev/null && firebase deploy --only hosting --project "$FIREBASE_PROJECT" && _ok "Deployed!" || _err "cd to repo first: hermes clone"
      else
        _err "Install firebase-tools: npm install -g firebase-tools"
      fi
      ;;
    run|cloudrun)
      _info "Cloud Run: $GATEWAY_RUN"
      _info "Deploy via: gcloud run deploy ai-vitality --source ."
      ;;
    *)
      printf '  %sTargets:%s\n' "$W" "$N"
      printf '  %scf%s          Deploy to hermes-cloudflare (CF Worker)\n' "$C" "$N"
      printf '  %sfirebase%s    Deploy to Firebase Hosting\n' "$C" "$N"
      printf '  %srun%s         Info: Cloud Run deploy\n' "$C" "$N"
      ;;
  esac
}

# ─── Clone/Sync Repos ───
cmd_clone() {
  _load_keys
  local repo="${1:-}"

  if [ -z "$GITHUB_PAT" ]; then
    _err "Set GITHUB_PAT first: hermes config GITHUB_PAT <token>"
    return 1
  fi

  mkdir -p "$HERMES_DIR/repo"

  case "$repo" in
    all)
      for r in roadfx-full-stack roadfx-ai-stack Solace-Hermes-Project ai-vitality; do
        _clone_repo "$r"
      done
      ;;
    "")
      _header "📦 CLONE REPOS"
      printf '  %sRepos:%s\n' "$W" "$N"
      printf '  %sfstack%s      roadfx-full-stack (Express + Firebase)\n' "$C" "$N"
      printf '  %sstack%s       roadfx-ai-stack (Backup)\n' "$C" "$N"
      printf '  %shermes%s      Solace-Hermes-Project (Gateway)\n' "$C" "$N"
      printf '  %svitality%s    ai-vitality (AI Studio)\n' "$C" "$N"
      printf '  %sall%s         Clone all\n' "$C" "$N"
      ;;
    fstack) _clone_repo "roadfx-full-stack" ;;
    stack)  _clone_repo "roadfx-ai-stack" ;;
    hermes) _clone_repo "Solace-Hermes-Project" ;;
    vitality) _clone_repo "ai-vitality" ;;
    *) _clone_repo "$repo" ;;
  esac
}

_clone_repo() {
  local name="$1"
  local dir="$HERMES_DIR/repo/$name"
  if [ -d "$dir" ]; then
    _info "Pulling $name..."
    cd "$dir" && git pull --ff-only 2>/dev/null && _ok "Updated $name" || _warn "Pull failed"
  else
    _info "Cloning $name..."
    git clone --depth 1 "https://x-access-token:${GITHUB_PAT}@github.com/${GH_USER}/${name}.git" "$dir" 2>/dev/null && _ok "Cloned $name" || _err "Clone failed"
  fi
}

# ─── Push to GitHub ───
cmd_push() {
  _load_keys
  local repo="${1:-roadfx-full-stack}"
  local dir="$HERMES_DIR/repo/$repo"
  local msg="${2:-update from hermes CLI}"

  if [ ! -d "$dir" ]; then
    _err "Repo not cloned: hermes clone"
    return 1
  fi

  _header "📤 PUSH — $repo"
  cd "$dir"
  git add -A
  if git diff --cached --quiet; then
    _info "Nothing to push"
  else
    git commit -m "$msg"
    git push origin main 2>/dev/null || git push origin master 2>/dev/null
    _ok "Pushed to $repo"
  fi
}

