  C=$'\e[36m'  M=$'\e[35m'  W=$'\e[1;37m' D=$'\e[2m'
  N=$'\e[0m'   BOLD=$'\e[1m'  O=$'\e[38;5;208m'
else
  R='' G='' Y='' B='' C='' M='' W='' D='' N='' BOLD='' O=''
fi

# ─── UI Helpers ───
_banner() {
  printf '\n'
  printf '  %s╔══════════════════════════════════════════════════════╗%s\n' "$O" "$N"
  printf '  %s║  ⚡ HERMES v%s — Full AI Agent CLI           ║%s\n' "$O" "$VERSION" "$N"
  printf '  %s║  Codename: %-10s  %s                    ║%s\n' "$O" "$CODENAME" "$(date '+%H:%M')" "$N"
  printf '  %s╚══════════════════════════════════════════════════════╝%s\n' "$O" "$N"
  printf '\n'
}

_info()  { printf '  %sℹ  %s%s\n' "$B" "$1" "$N"; }
_ok()    { printf '  %s✅ %s%s\n' "$G" "$1" "$N"; }
_warn()  { printf '  %s⚠️  %s%s\n' "$Y" "$1" "$N"; }
_err()   { printf '  %s❌ %s%s\n' "$R" "$1" "$N"; }
_line()  { printf '  %s%s%s\n' "$D" "$(printf '─%.0s' {1..56})" "$N"; }
_header(){ printf '\n  %s%s%s\n' "$W$BOLD" "$1" "$N"; _line; }

# ─── Setup ───
cmd_setup() {
