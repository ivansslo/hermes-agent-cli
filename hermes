    _ok "Keys file created: $HERMES_KEYS"
  else
    _ok "Keys file exists: $HERMES_KEYS"
  fi

  _load_keys
  _ok "Keys loaded"

  # Test connections
  echo ""
  _info "Testing AI providers..."
  _test_provider groq "Groq"
  _test_provider openrouter "OpenRouter"
  _test_provider gemini "Gemini"
  _test_gateway

  echo ""
