# ─── Quick Ask (non-interactive) ───
cmd_ask() {
  _load_keys
  local question="$*"
  if [ -z "$question" ]; then
    _err "Usage: hermes ask <question>"
    return 1
  fi

  local model="$DEFAULT_MODEL"
  local provider="$DEFAULT_PROVIDER"
  local messages='[{"role":"user","content":"'"$(echo "$question" | sed "s/\"/'/g")"'"}]'

  local response
  response=$(_call_ai "$provider" "$model" "$messages" 2048)
  echo "$response"
}

# ─── Crawl ───
cmd_crawl() {
  _load_keys
  local url="$1"
  if [ -z "$url" ]; then
    _err "Usage: hermes crawl <url>"
    return 1
  fi

  _header "🕷️ CRAWL4AI"
  _info "Crawling: $url"

  local response
  response=$(curl -s --max-time 30 -X POST "$DEFAULT_GATEWAY/crawl4ai" \
    -H "Authorization: Bearer $TOKEN" \
    -H "Content-Type: application/json" \
    -d "{\"url\":\"$url\",\"max_length\":50000}" 2>/dev/null)

  if [ -z "$response" ]; then
    _err "No response from gateway"
    return 1
  fi

  echo "$response" | python3 -c "
import json,sys
try:
    d=json.load(sys.stdin)
    text = d.get('markdown', d.get('text', d.get('content', json.dumps(d, indent=2))))
    print(text[:5000])
except: print(sys.stdin.read()[:5000])
" 2>/dev/null
}

