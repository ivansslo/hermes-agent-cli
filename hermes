}

_test_provider() {
  local prov="$1" name="$2"
  _load_keys
  local url key
  case "$prov" in
    groq)       url="https://api.groq.com/openai/v1/chat/completions"; key="$GROQ_KEY" ;;
    openrouter) url="https://openrouter.ai/api/v1/chat/completions"; key="$OR_KEY" ;;
    gemini)     url="https://generativelanguage.googleapis.com/v1beta/models?key=$GEMINI_KEY"; key="" ;;
  esac

  if [ -z "$key" ] && [ "$prov" != "gemini" ]; then
    printf '  %s⏭  %-12s %s\n' "$D" "$name" "no key" "$N"
    return
  fi

  local code
  if [ "$prov" = "gemini" ]; then
    code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 8 "$url" 2>/dev/null || echo "000")
  else
    code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 8 \
      -H "Authorization: Bearer $key" -H "Content-Type: application/json" \
      -d '{"model":"llama-3.3-70b-versatile","messages":[{"role":"user","content":"hi"}],"max_tokens":1}' \
      "$url" 2>/dev/null || echo "000")
  fi

  if [ "$code" = "200" ]; then
    printf '  %s✅ %-12s HTTP %s%s\n' "$G" "$name" "$code" "$N"
  else
    printf '  %s❌ %-12s HTTP %s%s\n' "$R" "$name" "$code" "$N"
  fi
}

_test_gateway() {
  _load_keys
  local code
  code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 8 "$DEFAULT_GATEWAY/health" 2>/dev/null || echo "000")
  if [ "$code" = "200" ]; then
    printf '  %s✅ %-12s HTTP %s%s\n' "$G" "Gateway" "$code" "$N"
  else
    printf '  %s❌ %-12s HTTP %s%s\n' "$R" "Gateway" "$code" "$N"
  fi
}

# ─── Config ───
cmd_config() {
  _load_keys
  if [ -n "${1:-}" ]; then
    # Set a key: hermes config KEY VALUE
    local key="$1" val="${2:-}"
    if [ -z "$val" ]; then
      printf '  Current: %s=%s\n' "$key" "${!key:-<not set>}"
      return
    fi
    # Update in file
    if grep -q "^${key}=" "$HERMES_KEYS" 2>/dev/null; then
      sed -i "s|^${key}=.*|${key}=${val}|" "$HERMES_KEYS"
    else
      echo "${key}=${val}" >> "$HERMES_KEYS"
    fi
    _ok "Set $key=$val"
  else
    _header "⚙️  CONFIG"
    printf '  %-20s %s\n' "TOKEN" "${TOKEN:+✅ set (${#TOKEN} chars)}${TOKEN:-❌ not set}"
    printf '  %-20s %s\n' "GROQ_KEY" "${GROQ_KEY:+✅ set}${GROQ_KEY:-❌ not set}"
    printf '  %-20s %s\n' "OR_KEY" "${OR_KEY:+✅ set}${OR_KEY:-❌ not set}"
    printf '  %-20s %s\n' "GEMINI_KEY" "${GEMINI_KEY:+✅ set}${GEMINI_KEY:-❌ not set}"
    printf '  %-20s %s\n' "GITHUB_PAT" "${GITHUB_PAT:+✅ set}${GITHUB_PAT:-❌ not set}"
    printf '  %-20s %s\n' "DEFAULT_MODEL" "$DEFAULT_MODEL"
    printf '  %-20s %s\n' "DEFAULT_PROVIDER" "$DEFAULT_PROVIDER"
    printf '  %-20s %s\n' "DEFAULT_GATEWAY" "$DEFAULT_GATEWAY"
    echo ""
    _info "Edit: nano $HERMES_KEYS"
    _info "Set:  hermes config KEY VALUE"
  fi
}

# ─── AI Chat ───
cmd_chat() {
  _load_keys
  local model="${1:-$DEFAULT_MODEL}"
  local provider="$DEFAULT_PROVIDER"

  # Auto-detect provider from model name
  case "$model" in
    google/*|gemini*|gemma*) provider="gemini" ;;
    openai/*|anthropic/*|deepseek/*|qwen/qwen3-235b*|mistralai/*|meta-llama/*:free|google/*:free) provider="openrouter" ;;
    *) provider="groq" ;;
  esac

  _header "💬 AI CHAT"
  printf '  Model:    %s%s%s\n' "$C" "$model" "$N"
  printf '  Provider: %s%s%s\n' "$C" "$provider" "$N"
  printf '  Gateway:  %s%s%s\n' "$D" "$DEFAULT_GATEWAY" "$N"
  _line
  printf '  %sCommands:%s /model <name> | /provider <name> | /system <prompt> | /clear | /quit\n' "$D" "$N"
  echo ""

  local system_prompt="You are Hermes, a helpful AI assistant. Be concise and accurate. Reply in the same language as the user."
  local messages="[]"
  local conversation=()

  while true; do
    printf '  %s❯%s ' "$O" "$N"
    read -r input

    [ -z "$input" ] && continue

    # Handle commands
    case "$input" in
      /quit|/exit|/q) echo ""; _ok "Goodbye!"; break ;;
      /clear) messages="[]"; conversation=(); _ok "Cleared"; continue ;;
      /model*) model="${input#/model }"; _ok "Model: $model"; continue ;;
      /provider*) provider="${input#/provider }"; _ok "Provider: $provider"; continue ;;
      /system*) system_prompt="${input#/system }"; _ok "System prompt updated"; continue ;;
      /models) cmd_models; continue ;;
      /status) cmd_status; continue ;;
      /help) _chat_help; continue ;;
      /save)
        echo "$messages" > "$HERMES_HISTORY"
        _ok "Saved to $HERMES_HISTORY"
        continue ;;
    esac

    # Add user message
    conversation+=("user:$input")

    # Build messages array
    local msg_json='[{"role":"system","content":"'"$system_prompt"'"}'
    for msg in "${conversation[@]}"; do
      local role="${msg%%:*}"
      local content="${msg#*:}"
      # Escape JSON
      content=$(echo "$content" | sed 's/"/\\"/g' | sed "s/'/\\\\'/g")
      msg_json="$msg_json"'{"role":"'"$role"'","content":"'"$content"'"}'
    done
    msg_json="$msg_json]"
    # Fix comma separation
    msg_json=$(echo "$msg_json" | sed 's/}{/},{/g')

    # Call API
    printf '  %s⏳ Thinking...%s\r' "$D" "$N"
    local response=""
    response=$(_call_ai "$provider" "$model" "$msg_json" 4096)

    if [ -z "$response" ]; then
      _err "No response. Check: hermes status"
      continue
    fi

    # Display response
    echo ""
    printf '  %s⚡ %s%s\n' "$G" "$N" "$response"
    echo ""

    # Add assistant message
    conversation+=("assistant:$response")
  done
}

_call_ai() {
  local provider="$1" model="$2" messages="$3" max_tokens="${4:-4096}"
  local url key headers body response

  case "$provider" in
    groq)
      url="https://api.groq.com/openai/v1/chat/completions"
      key="$GROQ_KEY"
      headers=(-H "Authorization: Bearer $key" -H "Content-Type: application/json")
      ;;
    openrouter)
      url="https://openrouter.ai/api/v1/chat/completions"
      key="$OR_KEY"
      headers=(-H "Authorization: Bearer $key" -H "Content-Type: application/json" -H "HTTP-Referer: https://hermes-cli" -H "X-Title: Hermes CLI")
      ;;
    gemini)
      # Use Gemini native API
      url="https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=$GEMINI_KEY"
      # Convert messages to Gemini format
      local gemini_contents
      gemini_contents=$(echo "$messages" | python3 -c "
import json,sys
msgs = json.load(sys.stdin)
contents = []
for m in msgs:
    if m['role'] == 'system': continue
    role = 'model' if m['role'] == 'assistant' else 'user'
    contents.append({'role': role, 'parts': [{'text': m['content']}]})
print(json.dumps(contents))
" 2>/dev/null || echo '[]')
      body="{\"contents\":$gemini_contents,\"generationConfig\":{\"maxOutputTokens\":$max_tokens}}"
      response=$(curl -s --max-time 60 -X POST "$url" -H "Content-Type: application/json" -d "$body" 2>/dev/null)
      echo "$response" | python3 -c "
import json,sys
try:
    d=json.load(sys.stdin)
    print(d['candidates'][0]['content']['parts'][0]['text'])
except: print('')
" 2>/dev/null
      return
      ;;
    gateway)
      url="$DEFAULT_GATEWAY/v1/chat/completions"
      key="$TOKEN"
      headers=(-H "Authorization: Bearer $key" -H "Content-Type: application/json")
      ;;
  esac

  body="{\"model\":\"$model\",\"messages\":$messages,\"max_tokens\":$max_tokens}"
  response=$(curl -s --max-time 60 -X POST "$url" "${headers[@]}" -d "$body" 2>/dev/null)
  echo "$response" | python3 -c "
import json,sys
try:
    d=json.load(sys.stdin)
    print(d['choices'][0]['message']['content'])
except Exception as e:
    try:
        print('Error: ' + d.get('error',{}).get('message','unknown'))
    except: print('')
" 2>/dev/null
}

