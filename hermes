  response=$(curl -s --max-time 120 -X POST "$DEFAULT_GATEWAY/solace/task" \
    -H "Authorization: Bearer $TOKEN" \
    -H "Content-Type: application/json" \
    -d "{
      \"type\": \"chat\",
      \"prompt\": \"You are a research crew. Research, analyze, and write a comprehensive report about: $topic. Provide: 1) Research findings, 2) Analysis & insights, 3) Recommendations.\",
      \"model\": \"llama-3.3-70b-versatile\",
      \"max_tokens\": 4096
    }" 2>/dev/null)

  echo "$response" | python3 -c "
import json,sys
try:
    d=json.load(sys.stdin)
    text = d.get('choices',[{}])[0].get('message',{}).get('content','')
    if not text: text = json.dumps(d, indent=2)
    print(text)
except: print(sys.stdin.read())
" 2>/dev/null
}

