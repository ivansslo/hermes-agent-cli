  # Create keys file
  if [ ! -f "$HERMES_KEYS" ]; then
    cat > "$HERMES_KEYS" << 'KEYS'
# Hermes Keys — Edit with: hermes config
TOKEN=
GROQ_KEY=
OR_KEY=
GEMINI_KEY=
GITHUB_PAT=
DEFAULT_MODEL=llama-3.3-70b-versatile
DEFAULT_PROVIDER=groq
DEFAULT_GATEWAY=https://hermes-cloudflare.certveis.workers.dev
