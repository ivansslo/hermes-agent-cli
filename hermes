# ─── Install Termux Dependencies ───
cmd_install_deps() {
  _header "📦 INSTALL TERMUX DEPENDENCIES"

  if ! command -v pkg &>/dev/null; then
    _warn "Not running on Termux. Skipping pkg install."
  else
    _info "Updating packages..."
    pkg update -y 2>/dev/null
    _info "Installing: python, curl, jq, git, nodejs..."
    pkg install -y python curl jq git nodejs 2>/dev/null
    _ok "Packages installed"
  fi

  _info "Installing npm tools..."
  npm install -g wrangler firebase-tools 2>/dev/null
  _ok "wrangler + firebase-tools installed"

  _info "Installing Python packages..."
  pip install crewai pyyaml requests 2>/dev/null
  _ok "Python packages installed"

  echo ""
  _ok "All dependencies installed!"
  _info "Run: hermes setup"
}

# ─── Update CLI ───
cmd_update() {
  _header "🔄 UPDATE — Hermes CLI"
  local script_path
  script_path="$(readlink -f "$0" 2>/dev/null || echo "$0")"

  _info "Downloading latest..."
  curl -sL "https://raw.githubusercontent.com/ivansslo/hermes-agent-cli/main/hermes" -o "/tmp/hermes_new" 2>/dev/null

  if [ -f "/tmp/hermes_new" ] && [ -s "/tmp/hermes_new" ]; then
    cp "/tmp/hermes_new" "$script_path"
    chmod +x "$script_path"
    _ok "Updated! Run: hermes --version"
  else
    _warn "Download failed. Using current version."
    _info "Manual update: curl -sL <url> -o $script_path"
  fi
}

# ─── Main ───
_load_keys

case "${1:-}" in
  chat|c)       shift; cmd_chat "$@" ;;
  ask|a|q)      shift; cmd_ask "$@" ;;
  crew|cr)      shift; cmd_crew "$@" ;;
  crawl)        shift; cmd_crawl "$@" ;;
  models|m)     cmd_models ;;
  scan|s)       cmd_scan ;;
  setup)        cmd_setup ;;
  config|cfg)   shift; cmd_config "$@" ;;
  status|st)    cmd_status ;;
  links|l)      cmd_links ;;
  clone)        shift; cmd_clone "$@" ;;
  push|p)       shift; cmd_push "$@" ;;
  deploy|d)     shift; cmd_deploy "$@" ;;
  install-deps) cmd_install_deps ;;
  update)       cmd_update ;;
  --version|-v) echo "hermes v$VERSION ($CODENAME)" ;;
  help|h|--help|-h|"") cmd_help ;;
  *)            _err "Unknown command: $1"; cmd_help ;;
esac
